# --- GitHub source (recommended for production) ---
# Point directly at the repo — no local clone needed.
REGISTRY_GITHUB_REPO=GLOBAL-PALO-IT/gen-e2-marketplace
# REGISTRY_GITHUB_BRANCH=main        # optional, default: main
# REGISTRY_GITHUB_TOKEN=ghp_xxx      # optional — increases rate limit from 60 to 5000 req/h

# --- Local source (for development / offline testing) ---
# Set REGISTRY_PATH instead of REGISTRY_GITHUB_REPO to use a local clone.
# REGISTRY_PATH=../gen-e2-marketplace
